{
  "$schema": "https://raw.githubusercontent.com/nicoulaj/mv/refs/heads/main/core/tauri/src/tauri-conf-schema.json",
  "productName": "ANTP Edge Daemon",
  "version": "0.1.0",
  "identifier": "com.antp.edge-daemon",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ANTP Edge Daemon",
        "label": "main",
        "width": 480,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; connect-src 'self' ws://localhost:* wss://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": false
    }
  }
}
