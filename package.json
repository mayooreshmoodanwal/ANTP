{
  "name": "antp",
  "version": "0.1.0",
  "private": true,
  "description": "ANTP — Decentralized Edge-Compute Orchestration Platform",
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "scripts": {
    "db:generate": "cd database && node --env-file=../.env.local node_modules/.bin/drizzle-kit generate",
    "db:push": "cd database && node --env-file=../.env.local node_modules/.bin/drizzle-kit push",
    "db:seed": "cd database && npx tsx seed.ts",
    "db:migrate": "cd database && npx tsx migrate.ts",
    "db:studio": "cd database && node --env-file=../.env.local node_modules/.bin/drizzle-kit studio",
    "orch:dev": "cd orchestrator && npx tsx src/index.ts",
    "orch:build": "cd orchestrator && npx tsc",
    "mock:cloud": "cd mock-cloud && npx tsx server.ts",
    "dev": "concurrently \"npm run orch:dev\" \"npm run mock:cloud\"",
    "daemon:build": "cd edge-daemon/src-tauri && cargo build",
    "daemon:dev": "cd edge-daemon/src-tauri && cargo build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
